# Server
AI_AGENT_HOST=0.0.0.0
AI_AGENT_PORT=8484
AI_AGENT_WORKERS=4
AI_AGENT_CORS_ORIGINS=["http://localhost:8080"]

# LLM
# Default provider is Ollama running locally. Other supported providers:
# openai, anthropic, google. For non-Ollama providers, set AI_AGENT_LLM_API_KEY
# and adjust AI_AGENT_LLM_BASE_URL / AI_AGENT_LLM_MODEL accordingly.
AI_AGENT_LLM_PROVIDER=ollama
AI_AGENT_LLM_BASE_URL=http://localhost:11434
AI_AGENT_LLM_API_KEY=
AI_AGENT_LLM_MODEL=qwen3.5:9b
AI_AGENT_LLM_TEMPERATURE=0.7
AI_AGENT_LLM_MAX_TOKENS=4096

# MCP
# Note: the MCP protocol endpoint is port 8081 (not 8080 which is the legacy REST API)
AI_AGENT_MCP_SERVER_URL=http://localhost:8081/mcp

# Frappe (for chat history persistence — AI Chat Session / AI Chat Message DocTypes)
AI_AGENT_FRAPPE_URL=http://localhost:8000

# Redis
AI_AGENT_REDIS_URL=redis://localhost:6379/0

# Rate Limiting
AI_AGENT_RATE_LIMIT_REQUESTS=60
AI_AGENT_RATE_LIMIT_WINDOW_SECONDS=60

# Observability
AI_AGENT_OTEL_ENDPOINT=
AI_AGENT_OTEL_SERVICE_NAME=copilot-agent
AI_AGENT_LOG_LEVEL=info
AI_AGENT_LOG_FORMAT=json
